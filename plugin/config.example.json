{
  "plugin": [
    [
      "opencode-remote-provider",
      {
        "installRoot": "~/.opencode-remote",
        "tunnel": {
          "localPortRange": [39000, 39999],
          "connectTimeoutMs": 15000,
          "healthTimeoutMs": 5000
        },
        "defaults": {
          "selectionStrategy": "first_available",
          "leaseMode": "exclusive",
          "stubPort": 39217
        },
        "providers": {
          "default": {
            "strategy": "first_available",
            "hosts": [
              {
                "name": "prod-web-1",
                "ssh": {
                  "host": "203.0.113.10",
                  "user": "ops",
                  "port": 22,
                  "identityFile": "~/.ssh/id_ed25519"
                },
                "labels": ["linux", "production"]
              },
              {
                "name": "staging-arm",
                "ssh": {
                  "host": "203.0.113.11",
                  "user": "ops",
                  "port": 22
                },
                "labels": ["linux", "staging", "arm64"]
              }
            ]
          }
        }
      }
    ]
  ]
}
